# ═══════════════════════════════════════════════════════
#  PaPeExpress — Variables de entorno
#  ⚠️  NUNCA subas este archivo a Git / GitHub
#  Agrega .env a tu .gitignore
# ═══════════════════════════════════════════════════════

# ── Django ──────────────────────────────────────────────
SECRET_KEY=cambia-esto-por-una-clave-secreta-larga-y-aleatoria
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de datos (SQLite por defecto) ──────────────────
# Para producción con PostgreSQL descomenta:
# DATABASE_URL=postgresql://usuario:contraseña@localhost/papeexpress

# ── Telegram ────────────────────────────────────────────
# Obtén el token con @BotFather en Telegram
TELEGRAM_BOT_TOKEN=
# ID del grupo/canal (empieza con -100...)
TELEGRAM_CHAT_ID=

# ── Stripe ──────────────────────────────────────────────
# Dashboard Stripe → Developers → API Keys
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
# Dashboard Stripe → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=

# ── Anthropic (análisis de tickets con IA) ───────────────
ANTHROPIC_API_KEY=
